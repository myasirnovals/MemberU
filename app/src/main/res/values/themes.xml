<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Theme MemberU Light Mode - Material Design 3 -->
    <style name="Base.Theme.MemberU" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary: Indigo - tombol utama, highlight, bottom nav aktif -->
        <item name="colorPrimary">#5C6BC0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#E8EAF6</item>
        <item name="colorOnPrimaryContainer">#1A237E</item>

        <!-- Secondary: Cyan - banner promo, aksen, badge tier -->
        <item name="colorSecondary">#26C6DA</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#E0F7FA</item>
        <item name="colorOnSecondaryContainer">#006064</item>

        <!-- Tertiary: Ungu - aksen tambahan card design -->
        <item name="colorTertiary">#7E57C2</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#EDE7F6</item>
        <item name="colorOnTertiaryContainer">#311B92</item>

        <!-- Background: Putih/Abu muda - background utama halaman -->
        <item name="android:colorBackground">#F5F5F7</item>
        <item name="colorOnBackground">#1C1B1F</item>

        <!-- Surface: Putih - Card, BottomSheet, Dialog -->
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1C1B1F</item>
        <item name="colorSurfaceVariant">#E8EAF6</item>
        <item name="colorOnSurfaceVariant">#49454F</item>

        <!-- Error: Merah - validasi form, error state -->
        <item name="colorError">#B00020</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorErrorContainer">#FDECEA</item>
        <item name="colorOnErrorContainer">#410002</item>

        <!-- Outline: Abu - border input field, divider, card border -->
        <item name="colorOutline">#C4C4C4</item>
        <item name="colorOutlineVariant">#E0E0E0</item>

        <!-- Status bar: warna primary, icon putih -->
        <item name="android:statusBarColor">#5C6BC0</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- Navigation bar: putih, icon gelap -->
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Shape: rounded corner untuk semua komponen UI -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MemberU.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MemberU.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MemberU.LargeComponent</item>

    </style>

    <!-- Main app theme -->
    <style name="Theme.MemberU" parent="Base.Theme.MemberU" />

    <!-- Splash screen theme - background primary brand color -->
    <style name="Theme.MemberU.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#5C6BC0</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenBrandingImage">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MemberU</item>
    </style>

    <!-- Shape: corner 8dp - tombol, chip, input kecil -->
    <style name="ShapeAppearance.MemberU.SmallComponent"
        parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Shape: corner 12dp - card sedang, dialog -->
    <style name="ShapeAppearance.MemberU.MediumComponent"
        parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Shape: corner 16dp - member card, bottom sheet -->
    <style name="ShapeAppearance.MemberU.LargeComponent"
        parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Member card: rounded corner, shadow ringan, border tipis -->
    <style name="Style.MemberU.MemberCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
        <item name="strokeColor">#E8EAF6</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Tombol utama: Tambah Member Baru, Simpan -->
    <style name="Style.MemberU.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">#5C6BC0</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tombol sekunder: outlined, warna primary -->
    <style name="Style.MemberU.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">#5C6BC0</item>
        <item name="android:textColor">#5C6BC0</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Tombol hapus: outlined, warna merah -->
    <style name="Style.MemberU.Button.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">#B00020</item>
        <item name="android:textColor">#B00020</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Input field: outlined box, rounded, error message aktif -->
    <style name="Style.MemberU.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">#5C6BC0</item>
        <item name="hintTextColor">#5C6BC0</item>
        <item name="errorTextColor">#B00020</item>
        <item name="errorIconDrawable">@null</item>
    </style>

    <!-- Bottom navigation: Cards, QRIS, Pengaturan -->
    <style name="Style.MemberU.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Style.MemberU.BottomNavIndicator</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="android:background">#FFFFFF</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Bottom nav indicator: background aktif rounded -->
    <style name="Style.MemberU.BottomNavIndicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#E8EAF6</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MemberU.SmallComponent</item>
    </style>

    <!-- Filter chip: Semua, Gym, Barbershop, Laundry -->
    <style name="Style.MemberU.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipStrokeColor">#5C6BC0</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Search bar: "Cari member" di Home Screen -->
    <style name="Style.MemberU.SearchBar" parent="Widget.Material3.SearchBar">
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:textColor">#1C1B1F</item>
        <item name="android:textColorHint">#9E9E9E</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Top app bar: putih, tanpa elevation -->
    <style name="Style.MemberU.TopAppBar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">#FFFFFF</item>
        <item name="titleTextColor">#1C1B1F</item>
        <item name="subtitleTextColor">#49454F</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Dialog konfirmasi: hapus kartu, logout -->
    <style name="Style.MemberU.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">#5C6BC0</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MemberU.MediumComponent</item>
    </style>

    <!-- Tier badge Gold: teks coklat keemasan -->
    <style name="Style.MemberU.TierBadge.Gold">
        <item name="android:background">@drawable/bg_tier_gold</item>
        <item name="android:textColor">#7B5800</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Tier badge Silver: teks abu biru -->
    <style name="Style.MemberU.TierBadge.Silver">
        <item name="android:background">@drawable/bg_tier_silver</item>
        <item name="android:textColor">#455A64</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Tier badge Platinum: teks abu gelap -->
    <style name="Style.MemberU.TierBadge.Platinum">
        <item name="android:background">@drawable/bg_tier_platinum</item>
        <item name="android:textColor">#37474F</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- QR Code container: background putih agar mudah discan -->
    <style name="Style.MemberU.QRCodeContainer">
        <item name="android:background">@drawable/bg_qr_container</item>
        <item name="android:padding">16dp</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Judul halaman: besar, bold -->
    <style name="TextAppearance.MemberU.PageTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">#1C1B1F</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!-- Nama merchant di card: medium-large, semi-bold -->
    <style name="TextAppearance.MemberU.MerchantName" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">#1C1B1F</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ID member di card: abu sedang -->
    <style name="TextAppearance.MemberU.MemberID" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">#49454F</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Metadata kartu: kecil, abu muda -->
    <style name="TextAppearance.MemberU.Metadata" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">#9E9E9E</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Label tombol: putih, bold -->
    <style name="TextAppearance.MemberU.ButtonLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Header section: primary color, huruf kapital kecil -->
    <style name="TextAppearance.MemberU.SectionHeader" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">#5C6BC0</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

</resources>
