<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Theme MemberU Light Mode - Material Design 3 -->
    <style name="Base.Theme.MemberU" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorOnBackground">@color/on_background_light</item>

        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_light</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <item name="android:navigationBarColor">@color/surface_light</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Shape: rounded corner untuk semua komponen UI -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MemberU.SmallComponent
        </item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MemberU.MediumComponent
        </item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MemberU.LargeComponent
        </item>

    </style>

    <!-- Main app theme -->
    <style name="Theme.MemberU" parent="Base.Theme.MemberU" />

    <!-- Shape: corner 8dp - tombol, chip, input kecil -->
    <style name="ShapeAppearance.MemberU.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Shape: corner 12dp - card sedang, dialog -->
    <style name="ShapeAppearance.MemberU.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Shape: corner 16dp - member card, bottom sheet -->
    <style name="ShapeAppearance.MemberU.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Member card: rounded corner, shadow ringan, border tipis -->
    <style name="Style.MemberU.MemberCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg_light</item>
        <item name="strokeColor">@color/card_stroke_light</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Tombol utama: Tambah Member Baru, Simpan -->
    <style name="Style.MemberU.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tombol sekunder: outlined, warna primary -->
    <style name="Style.MemberU.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Tombol hapus: outlined, warna merah -->
    <style name="Style.MemberU.Button.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/error</item>
        <item name="android:textColor">@color/error</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Input field: outlined box, rounded, error message aktif -->
    <style name="Style.MemberU.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="errorTextColor">@color/error</item>
        <item name="errorIconDrawable">@null</item>
    </style>

    <!-- Bottom navigation: Cards, QRIS, Pengaturan -->
    <style name="Style.MemberU.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Style.MemberU.BottomNavIndicator</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="android:background">@color/surface_light</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Bottom nav indicator: background aktif rounded -->
    <style name="Style.MemberU.BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MemberU.SmallComponent</item>
    </style>

    <!-- Filter chip: Semua, Gym, Barbershop, Laundry -->
    <style name="Style.MemberU.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Search bar: "Cari member" di Home Screen -->
    <style name="Style.MemberU.SearchBar" parent="Widget.Material3.SearchBar">
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Top app bar: putih, tanpa elevation -->
    <style name="Style.MemberU.TopAppBar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/surface_light</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Dialog konfirmasi: hapus kartu, logout -->
    <style name="Style.MemberU.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MemberU.MediumComponent
        </item>
    </style>

    <!-- Tier badge Gold: teks coklat keemasan -->
    <style name="Style.MemberU.TierBadge.Gold">
        <item name="android:background">@drawable/bg_tier_gold</item>
        <item name="android:textColor">@color/tier_gold_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Tier badge Silver: teks abu biru -->
    <style name="Style.MemberU.TierBadge.Silver">
        <item name="android:background">@drawable/bg_tier_silver</item>
        <item name="android:textColor">@color/tier_silver_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Tier badge Platinum: teks abu gelap -->
    <style name="Style.MemberU.TierBadge.Platinum">
        <item name="android:background">@drawable/bg_tier_platinum</item>
        <item name="android:textColor">@color/tier_platinum_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- QR Code container: background putih agar mudah discan -->
    <style name="Style.MemberU.QRCodeContainer">
        <item name="android:background">@drawable/bg_qr_container</item>
        <item name="android:padding">16dp</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Judul halaman: besar, bold -->
    <style name="TextAppearance.MemberU.PageTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!-- Nama merchant di card: medium-large, semi-bold -->
    <style name="TextAppearance.MemberU.MerchantName" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ID member di card: abu sedang -->
    <style name="TextAppearance.MemberU.MemberID" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Metadata kartu: kecil, abu muda -->
    <style name="TextAppearance.MemberU.Metadata" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Label tombol: putih, bold -->
    <style name="TextAppearance.MemberU.ButtonLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Header section: primary color, huruf kapital kecil -->
    <style name="TextAppearance.MemberU.SectionHeader" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Style.MemberU" parent="" />

    <style name="Style.MemberU.TierBadge" parent="" />

</resources>