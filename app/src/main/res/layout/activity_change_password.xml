<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F8"
    android:orientation="vertical">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#6B4EFF"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btnBackPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Ganti Password"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Form Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password Saat Ini"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPasswordLama"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/edit_text"
            android:hint="Masukkan password lama"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password Baru"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPasswordBaru"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/edit_text"
            android:hint="Minimal 6 karakter"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konfirmasi Password Baru"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPasswordKonfirmasi"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ulangi password baru"
            android:inputType="textPassword"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSimpanPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="#6B4EFF"
            android:text="Perbarui Password"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>